# Contexto de build: raíz de Caronte (donde están dockerfiles/ y proyectos/)
CONTEXTO=../../../

# Nombre del proyecto (se pasa como ARG al Dockerfile)
PROYECTO=pnest

# Nombre del contenedor
NOMBRE=pnest

# Puerto del host → puerto del contenedor (3000)
PORT_WEB=3000

# Red interna
IP=172.20.0.10
SUBNET=172.20.0.0/24
